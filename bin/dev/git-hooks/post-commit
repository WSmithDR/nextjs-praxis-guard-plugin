#!/bin/bash
# post-commit: auto-bump de la versión en .claude-plugin/plugin.json según el
# prefijo del commit (conventional commits) y amend del commit para incluir el cambio.
#
# Adaptado del feature `versioning` de cli-plugin-template para un plugin de un solo
# manifiesto (sin bump-version.py, sin marketplace.json): bumpea plugin.json directo.
#
#   feat:                 -> minor
#   fix|chore|docs|...     -> patch
#   feat!: / BREAKING      -> major
#
# Recursión: el `git commit --amend` de abajo re-dispara post-commit (--no-verify NO lo
# saltea). Un sentinel file garantiza un único bump por commit.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"
SENTINEL="$REPO_ROOT/.git/.version-bump-in-progress"

# Guard de recursión: la invocación re-disparada por el amend sale acá.
if [ -f "$SENTINEL" ]; then rm -f "$SENTINEL"; exit 0; fi
[ ! -f "$PLUGIN_JSON" ] && exit 0

# Si plugin.json ya entró en este commit (bump manual), no tocar.
if git show --name-only --format="" HEAD | grep -qx "\.claude-plugin/plugin\.json"; then exit 0; fi

MSG=$(git log -1 --pretty=%B)
if echo "$MSG" | grep -qiE "(BREAKING[ -]CHANGE|^.+!:)"; then BUMP="major"
elif echo "$MSG" | grep -qiE "^feat(\(.+\))?:"; then BUMP="minor"
else BUMP="patch"; fi

# Bump quirúrgico de la línea de versión: preserva el resto del archivo byte a byte
# (no re-serializa el JSON, así no toca tildes ni el formato). Valores por env, no
# interpolados en el código Python (seguridad).
OUT=$(BUMP="$BUMP" PLUGIN_JSON="$PLUGIN_JSON" python3 - <<'PY'
import os, re, sys
path, bump = os.environ['PLUGIN_JSON'], os.environ['BUMP']
txt = open(path, encoding='utf-8').read()
m = re.search(r'("version"\s*:\s*")(\d+)\.(\d+)\.(\d+)(")', txt)
if not m: sys.exit('no se encontró "version" en ' + path)
major, minor, patch = int(m.group(2)), int(m.group(3)), int(m.group(4))
old = f'{major}.{minor}.{patch}'
if bump == 'major': major, minor, patch = major + 1, 0, 0
elif bump == 'minor': minor, patch = minor + 1, 0
else: patch += 1
new = f'{major}.{minor}.{patch}'
open(path, 'w', encoding='utf-8').write(txt[:m.start()] + m.group(1) + new + m.group(5) + txt[m.end():])
print(old + ' ' + new)
PY
)
read -r OLD NEW <<< "$OUT"

git add "$PLUGIN_JSON"
touch "$SENTINEL"
git commit --amend --no-edit --no-verify
rm -f "$SENTINEL"
echo "  version: $OLD → $NEW ($BUMP)"
