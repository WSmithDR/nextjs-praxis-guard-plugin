#!/bin/bash
# post-commit: auto-bump de la versión según el prefijo del commit (conventional commits)
# y amend del commit para incluir el cambio. Delega en bin/bump-version.py, que sincroniza
# TODOS los manifiestos por-CLI (.claude-plugin / .codex-plugin / .copilot-plugin / gemini),
# no solo el de Claude (eso era el bug del drift).
#
#   feat:                 -> minor
#   fix|chore|docs|...     -> patch
#   feat!: / BREAKING      -> major
#
# Recursión: el `git commit --amend` de abajo re-dispara post-commit (--no-verify NO lo
# saltea). Un sentinel file garantiza un único bump por commit.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"
BUMPER="$REPO_ROOT/bin/bump-version.py"
SENTINEL="$REPO_ROOT/.git/.version-bump-in-progress"

# Guard de recursión: la invocación re-disparada por el amend sale acá.
if [ -f "$SENTINEL" ]; then rm -f "$SENTINEL"; exit 0; fi
[ ! -f "$PLUGIN_JSON" ] && exit 0
[ ! -f "$BUMPER" ] && exit 0

# Si plugin.json ya entró en este commit (bump manual), no tocar.
if git show --name-only --format="" HEAD | grep -qx "\.claude-plugin/plugin\.json"; then exit 0; fi

MSG=$(git log -1 --pretty=%B)
if echo "$MSG" | grep -qiE "(BREAKING[ -]CHANGE|^.+!:)"; then BUMP="major"
elif echo "$MSG" | grep -qiE "^feat(\(.+\))?:"; then BUMP="minor"
else BUMP="patch"; fi

OLD=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['version'])" "$PLUGIN_JSON")
# Delega: bumpea el canónico y propaga a TODOS los manifiestos por-CLI.
python3 "$BUMPER" "$BUMP" >/dev/null
NEW=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['version'])" "$PLUGIN_JSON")

# Stagiar todos los manifiestos con version que existan.
for f in .claude-plugin/plugin.json .codex-plugin/plugin.json .copilot-plugin/plugin.json gemini-extension.json; do
  [ -f "$REPO_ROOT/$f" ] && git -C "$REPO_ROOT" add "$f"
done
touch "$SENTINEL"
git commit --amend --no-edit --no-verify
rm -f "$SENTINEL"
echo "  version: $OLD → $NEW ($BUMP) [todos los manifiestos]"
